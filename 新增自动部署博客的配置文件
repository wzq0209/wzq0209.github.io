.github/workflows/deploy.yml
name: Hugo自动构建部署博客
on:
  push:
    branches: [ main ]
permissions:
  contents: read
  pages: write
  id-token: write
concurrency:
  group: pages
  cancel-in-progress: false
jobs:
  build-deploy:
    runs-on: ubuntu-latest
    steps:
      - name: 拉取博客源码
        uses: actions/checkout@v6
        with:
          submodules: recursive
      - name: 安装Hugo扩展版
        uses: peaceiris/actions-hugo@v2
        with:
          hugo-version: latest
          extended: true
      - name: 编译生成静态网站
        run: hugo --gc --minify
      - name: 上传网页产物
        uses: actions/upload-pages-artifact@v3
        with:
          path: ./public
      - name: 部署到GitHub Pages
        uses: actions/deploy-pages@v4
